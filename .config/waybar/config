{
    "layer": "top",
        "position" : "top",
        "mode" : "dock",
        "exclusive" : true,
        "passthrough" : false,
        "fixed-center" : true,
        "gtk-layer-shell" : true,
        "height" : 29,
        "spacing": 5,
        "modules-left": ["wlr/workspaces", ],
        "modules-center": ["hyprland/window", ],
        "modules-right": [ "cpu", "wireplumber", "network", "clock", "tray"],

        "clock": {
          "tooltip" : false,
          "format" : "󱑎 {:%H:%M}"
        },
        "cpu": {
         "interval": 10,
         "format": "{}% ",
         "max-length": 10
        },
        "wlr/workspaces": {
        "on-click": "activate",
         "format": "{icon}",
         "format-icons": {
             "1": "",
             "2": "",
             "3": "",
             "4": "",
             "5": "",
             "6": "",
             },
        },

        "wlr/taskbar": {
         "on-click": "activate",
         "on-click-right": "close",
        }
}
